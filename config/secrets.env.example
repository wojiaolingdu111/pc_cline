# =============================================================================
# CI 统一凭据配置文件
# 复制此文件为 secrets.env 并填入真实值，请勿将 secrets.env 提交到仓库。
# =============================================================================

# ---- Gitee 相关 ----
GITEE_USERNAME=YOUR_GITEE_USERNAME
GITEE_TOKEN=YOUR_GITEE_PERSONAL_ACCESS_TOKEN
GITEE_REPO=imglingdu/pc_clinet

# ---- 七牛云 ----
QINIU_AK=YOUR_QINIU_ACCESS_KEY
QINIU_SK=YOUR_QINIU_SECRET_KEY
QINIU_BUCKET=YOUR_QINIU_BUCKET_NAME
QINIU_DOMAIN=YOUR_QINIU_CDN_DOMAIN

# ---- 触发 GitHub Actions 所需 ----
GITHUB_PAT=YOUR_GITHUB_PERSONAL_ACCESS_TOKEN
GH_REPO=your-org/ci-trigger-repo

# ---- qshell 路径（CI 环境已预装时留空） ----
QSHELL_PATH=qshell
